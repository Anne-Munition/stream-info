/* https://www.staging-typescript.org/tsconfig */

{
  "compilerOptions": {
    "target": "ES6",
    "module": "Node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "removeComments": true,
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "lib": ["ES6", "DOM"]
  },
  "include": ["./src/**/*"]
}
